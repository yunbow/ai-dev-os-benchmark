// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TeamRole {
  OWNER
  MEMBER
  VIEWER
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  password       String?
  emailVerified  DateTime?
  role           UserRole  @default(USER)
  sessionVersion Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  tasks             Task[]           @relation("CreatedTasks")
  assignedTasks     Task[]           @relation("AssignedTasks")
  categories        Category[]
  teamMemberships   TeamMember[]
  teamInvitationsSent TeamInvitation[] @relation("InvitedByUser")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model Task {
  id          String       @id @default(cuid())
  title       String       @db.VarChar(200)
  description String?      @db.VarChar(2000)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  creatorId  String
  creator    User      @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?     @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  teamId     String?
  team       Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([creatorId])
  @@index([assigneeId])
  @@index([teamId])
  @@index([categoryId])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(50)
  color     String   @db.VarChar(7)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([userId])
  @@index([teamId])
  @@map("categories")
}

model Team {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     TeamMember[]
  tasks       Task[]
  categories  Category[]
  invitations TeamInvitation[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

model TeamInvitation {
  id        String    @id @default(cuid())
  email     String
  teamId    String
  token     String    @unique
  role      TeamRole  @default(MEMBER)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  invitedById String?
  invitedBy   User?   @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: SetNull)
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([teamId])
  @@map("team_invitations")
}
