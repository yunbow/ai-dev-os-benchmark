// Prisma schema additions for password reset flow

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String
  name           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  passwordResets PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique  // NO @default — generated by crypto.randomBytes in application code
  userId    String
  expiresAt DateTime
  usedAt    DateTime?          // null = unused; set on redemption (single-use)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
